{
  "name": "portifolio",
  "compatibility_date": "2026-02-18",
  "assets": {
    "directory": "./out",
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
  "logs": {
    "enabled": true,
    "head_sampling_rate": 1,
    "persist": true,
    "invocation_logs": true,
  },
  "traces": {
    "enabled": false,
    "persist": true,
    "head_sampling_rate": 1,
  },
}
